# Sanity configuration.
# Copy this file to `.env.local` and fill in the values from your Sanity
# project at https://www.sanity.io/manage. Until these are set, the site
# falls back to the local content in content/home.ts.

# Required: your Sanity project id (e.g. "abc12xyz").
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset name. "production" is the default Sanity creates for you.
NEXT_PUBLIC_SANITY_DATASET=production

# API version — pin to a date; bump intentionally when you want new API behaviour.
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
